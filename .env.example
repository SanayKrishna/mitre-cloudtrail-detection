# Copy to .env and adjust. NEVER commit real secrets or credentials.

# AWS region used for live CloudTrail ingestion via boto3.
AWS_REGION=us-east-1

# Named AWS profile (from ~/.aws/credentials) for live ingestion. Leave blank
# to use the default credential chain (env vars, SSO, instance role, ...).
AWS_PROFILE=

# Path to a CloudTrail log file or a directory of *.json log files, used by
# the file-based reader. Optional.
CLOUDTRAIL_LOG_PATH=./data/sample_cloudtrail.json

# Path to the MITRE ATT&CK enterprise STIX bundle. Defaults to
# ./data/enterprise-attack.json if unset.
STIX_DATA_PATH=./data/enterprise-attack.json

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Comma-separated regions your org legitimately operates in. Activity outside
# this set raises a T1535 (Unused/Unsupported Cloud Regions) alert.
EXPECTED_REGIONS=us-east-1,us-west-2
